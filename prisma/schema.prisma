generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                                       String                           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                                     String
  code                                     String                           @unique @db.VarChar(32)
  subdomain                                String                           @unique @db.VarChar(128)
  theme                                    Json                             @default("{\"accent\": \"#f57f17\", \"primary\": \"#0f5a6e\"}")
  features                                 Json                             @default("{\"inventory\": true, \"telehealth\": false}")
  status                                   String                           @default("active") @db.VarChar(16)
  created_at                               DateTime                         @default(now()) @db.Timestamptz(6)
  updated_at                               DateTime                         @default(now()) @db.Timestamptz(6)
  subscription_tier                        String?                          @default("Basic") @db.VarChar(50)
  billing_config                           Json?                            @default("{\"currency\": \"INR\", \"provider\": \"manual\", \"gatewayKey\": \"\", \"accountStatus\": \"unlinked\"}")
  logo_url                                 String?
  contact_email                            String?                          @db.VarChar(255)
  ambulances                               ambulances[]
  appointments                             Appointment[]
  attendance                               attendance[]
  audit_logs                               audit_logs[]
  beds                                     beds[]
  blood_requests                           blood_requests[]
  blood_units                              blood_units[]
  chat_threads                             chat_threads[]
  claims                                   claims[]
  clinical_records                         clinical_records[]
  conditions                               conditions[]
  departments                              Department[]
  diagnostic_reports                       diagnostic_reports[]
  document_access_policies                 document_access_policies[]
  document_audit_logs                      document_audit_logs[]
  documents                                documents[]
  donors                                   donors[]
  drug_allergies                           drug_allergies[]
  drug_batches                             drug_batches[]
  drug_master                              drug_master[]
  employee_leaves                          employee_leaves[]
  employees                                Employee[]
  encounters                               Encounter[]
  expenses                                 expenses[]
  feature_flag_audit                       feature_flag_audit[]
  frontdesk_visits                         frontdesk_visits[]
  insurance_providers                      insurance_providers[]
  inventory_items                          inventory_items[]
  inventory_transactions                   inventory_transactions[]
  invoice_items                            invoice_items[]
  invoices                                 Invoice[]
  locations                                locations[]
  medication_administrations               medication_administrations[]
  medication_schedules                     medication_schedules[]
  notices                                  notices[]
  notification_jobs                        notification_jobs[]
  notification_logs                        notification_logs[]
  notification_templates                   notification_templates[]
  observations                             observations[]
  patient_medication_allocations           patient_medication_allocations[]
  patients                                 Patient[]
  payroll_items                            payroll_items[]
  payroll_runs                             payroll_runs[]
  payslips                                 payslips[]
  pharmacy_alerts                          pharmacy_alerts[]
  pharmacy_inventory                       pharmacy_inventory[]
  prescriptions                            prescriptions[]
  procedures                               procedures[]
  purchase_orders                          purchase_orders[]
  role_permissions                         role_permissions[]
  roles                                    roles[]
  salary_structures                        salary_structures[]
  service_requests                         service_requests[]
  services                                 Service[]
  support_tickets                          support_tickets[]
  tenant_communications                    tenant_communications[]
  tenant_features                          tenant_features[]
  users                                    User[]
  vendors                                  vendors[]
  walkins                                  walkins[]
  ward_stock_ward_stock_tenant_idTotenants ward_stock[]                     @relation("ward_stock_tenant_idTotenants")
  ward_stock_ward_stock_ward_idTotenants   ward_stock[]                     @relation("ward_stock_ward_idTotenants")
  wards                                    wards[]

  @@index([code], map: "idx_tenants_code")
  @@index([status], map: "idx_tenants_status")
  @@index([subdomain], map: "idx_tenants_subdomain")
  @@map("tenants")
}

model User {
  id                                                                           String                           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id                                                                    String?                          @db.Uuid
  email                                                                        String
  password_hash                                                                String
  name                                                                         String
  role                                                                         String                           @db.VarChar(32)
  patient_id                                                                   String?                          @db.Uuid
  is_active                                                                    Boolean                          @default(true)
  last_login                                                                   DateTime?                        @db.Timestamptz(6)
  created_at                                                                   DateTime                         @default(now()) @db.Timestamptz(6)
  updated_at                                                                   DateTime                         @default(now()) @db.Timestamptz(6)
  appointments                                                                 Appointment[]
  audit_logs                                                                   audit_logs[]
  blood_requests_blood_requests_approved_byTousers                             blood_requests[]                 @relation("blood_requests_approved_byTousers")
  blood_requests_blood_requests_requested_byTousers                            blood_requests[]                 @relation("blood_requests_requested_byTousers")
  blood_units                                                                  blood_units[]
  chat_messages                                                                chat_messages[]
  chat_participants                                                            chat_participants[]
  chat_threads                                                                 chat_threads[]
  clinical_records                                                             clinical_records[]
  conditions                                                                   conditions[]
  departments_departments_created_byTousers                                    Department[]                     @relation("departments_created_byTousers")
  departments_departments_hod_user_idTousers                                   Department[]                     @relation("departments_hod_user_idTousers")
  diagnostic_reports_diagnostic_reports_created_byTousers                      diagnostic_reports[]             @relation("diagnostic_reports_created_byTousers")
  diagnostic_reports_diagnostic_reports_performer_idTousers                    diagnostic_reports[]             @relation("diagnostic_reports_performer_idTousers")
  document_audit_logs                                                          document_audit_logs[]
  documents                                                                    documents[]
  donors                                                                       donors[]
  drug_allergies                                                               drug_allergies[]
  employee_leaves                                                              employee_leaves[]
  encounters                                                                   Encounter[]
  expenses                                                                     expenses[]
  feature_flag_audit                                                           feature_flag_audit[]
  frontdesk_visits_frontdesk_visits_checked_in_byTousers                       frontdesk_visits[]               @relation("frontdesk_visits_checked_in_byTousers")
  frontdesk_visits_frontdesk_visits_doctor_idTousers                           frontdesk_visits[]               @relation("frontdesk_visits_doctor_idTousers")
  inventory_transactions                                                       inventory_transactions[]
  medication_administrations_medication_administrations_administered_byTousers medication_administrations[]     @relation("medication_administrations_administered_byTousers")
  medication_administrations_medication_administrations_verified_byTousers     medication_administrations[]     @relation("medication_administrations_verified_byTousers")
  notices                                                                      notices[]
  notification_jobs                                                            notification_jobs[]
  notification_templates                                                       notification_templates[]
  observations_observations_created_byTousers                                  observations[]                   @relation("observations_created_byTousers")
  observations_observations_performer_idTousers                                observations[]                   @relation("observations_performer_idTousers")
  patient_medication_allocations                                               patient_medication_allocations[]
  payroll_runs_payroll_runs_approved_byTousers                                 payroll_runs[]                   @relation("payroll_runs_approved_byTousers")
  payroll_runs_payroll_runs_created_byTousers                                  payroll_runs[]                   @relation("payroll_runs_created_byTousers")
  pharmacy_alerts                                                              pharmacy_alerts[]
  pharmacy_inventory                                                           pharmacy_inventory[]
  prescription_items                                                           prescription_items[]
  prescriptions                                                                prescriptions[]
  procedures_procedures_created_byTousers                                      procedures[]                     @relation("procedures_created_byTousers")
  procedures_procedures_performer_idTousers                                    procedures[]                     @relation("procedures_performer_idTousers")
  purchase_orders_purchase_orders_approved_byTousers                           purchase_orders[]                @relation("purchase_orders_approved_byTousers")
  purchase_orders_purchase_orders_ordered_byTousers                            purchase_orders[]                @relation("purchase_orders_ordered_byTousers")
  purchase_orders_purchase_orders_received_byTousers                           purchase_orders[]                @relation("purchase_orders_received_byTousers")
  salary_structures                                                            salary_structures[]
  service_requests_service_requests_created_byTousers                          service_requests[]               @relation("service_requests_created_byTousers")
  service_requests_service_requests_ordered_by_idTousers                       service_requests[]               @relation("service_requests_ordered_by_idTousers")
  sessions                                                                     sessions[]
  support_tickets                                                              support_tickets[]
  tenants                                                                      Tenant?                          @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tenant_id, email])
  @@index([email], map: "idx_users_email")
  @@index([patient_id], map: "idx_users_patient_id")
  @@index([role], map: "idx_users_role")
  @@index([tenant_id], map: "idx_users_tenant")
  @@map("users")
}

model Patient {
  id                             String                           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id                      String                           @db.Uuid
  mrn                            String                           @db.VarChar(64)
  first_name                     String
  last_name                      String
  date_of_birth                  DateTime?                        @db.Date
  gender                         String?                          @db.VarChar(16)
  phone                          String?                          @db.VarChar(32)
  email                          String?
  address                        String?
  blood_group                    String?                          @db.VarChar(8)
  emergency_contact              String?                          @db.VarChar(128)
  insurance                      String?                          @db.VarChar(256)
  medical_history                Json                             @default("{\"allergies\": \"\", \"surgeries\": \"\", \"familyHistory\": \"\", \"chronicConditions\": \"\"}")
  created_at                     DateTime                         @default(now()) @db.Timestamptz(6)
  updated_at                     DateTime                         @default(now()) @db.Timestamptz(6)
  fhir_patient_ref               String?                          @db.Uuid
  ethnicity                      String?                          @db.VarChar(64)
  language                       String?                          @db.VarChar(64)
  birth_place                    String?
  is_archived                    Boolean?                         @default(false)
  appointments                   Appointment[]
  blood_requests                 blood_requests[]
  claims                         claims[]
  clinical_records               clinical_records[]
  conditions                     conditions[]
  diagnostic_reports             diagnostic_reports[]
  documents                      documents[]
  drug_allergies                 drug_allergies[]
  encounters                     Encounter[]
  frontdesk_visits               frontdesk_visits[]
  invoices                       Invoice[]
  medication_administrations     medication_administrations[]
  medication_schedules           medication_schedules[]
  observations                   observations[]
  patient_medication_allocations patient_medication_allocations[]
  tenants                        Tenant                           @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  pharmacy_alerts                pharmacy_alerts[]
  prescriptions                  prescriptions[]
  procedures                     procedures[]
  service_requests               service_requests[]
  walkins                        walkins[]

  @@unique([tenant_id, mrn])
  @@index([first_name, last_name], map: "idx_patients_name")
  @@index([tenant_id], map: "idx_patients_tenant")
  @@index([tenant_id, mrn], map: "idx_patients_tenant_mrn")
  @@map("patients")
}

model Appointment {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String             @db.Uuid
  patient_id       String             @db.Uuid
  provider_id      String?            @db.Uuid
  scheduled_start  DateTime           @db.Timestamptz(6)
  scheduled_end    DateTime           @db.Timestamptz(6)
  status           String             @default("scheduled") @db.VarChar(16)
  reason           String?
  source           String?            @default("staff") @db.VarChar(16)
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime           @default(now()) @db.Timestamptz(6)
  patients         Patient            @relation(fields: [patient_id], references: [id], onUpdate: NoAction)
  users            User?              @relation(fields: [provider_id], references: [id], onUpdate: NoAction)
  tenants          Tenant             @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  frontdesk_visits frontdesk_visits[]

  @@index([patient_id], map: "idx_appointments_patient")
  @@index([status], map: "idx_appointments_status")
  @@index([tenant_id, provider_id, scheduled_start], map: "idx_appointments_tenant_provider_start")
  @@map("appointments")
}

model Encounter {
  id                         String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id                  String                       @db.Uuid
  patient_id                 String                       @db.Uuid
  provider_id                String?                      @db.Uuid
  encounter_type             String                       @db.VarChar(16)
  visit_date                 DateTime                     @default(dbgenerated("CURRENT_DATE")) @db.Date
  chief_complaint            String?
  diagnosis                  String?
  notes                      String?
  status                     String                       @default("open") @db.VarChar(16)
  created_at                 DateTime                     @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime                     @default(now()) @db.Timestamptz(6)
  fhir_encounter_ref         String?                      @db.Uuid
  blood_requests             blood_requests[]
  claims                     claims[]
  diagnostic_reports         diagnostic_reports[]
  documents                  documents[]
  patients                   Patient                      @relation(fields: [patient_id], references: [id], onUpdate: NoAction)
  users                      User?                        @relation(fields: [provider_id], references: [id], onUpdate: NoAction)
  tenants                    Tenant                       @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  invoices                   Invoice[]
  medication_administrations medication_administrations[]
  medication_schedules       medication_schedules[]
  observations               observations[]
  prescriptions              prescriptions[]
  procedures                 procedures[]
  service_requests           service_requests[]

  @@index([provider_id], map: "idx_encounters_provider")
  @@index([tenant_id, patient_id, visit_date], map: "idx_encounters_tenant_patient_visit")
  @@map("encounters")
}

model Invoice {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id      String          @db.Uuid
  patient_id     String          @db.Uuid
  encounter_id   String?         @db.Uuid
  invoice_number String          @db.VarChar(64)
  description    String?
  subtotal       Decimal         @default(0) @db.Decimal(12, 2)
  tax            Decimal         @default(0) @db.Decimal(12, 2)
  total          Decimal         @default(0) @db.Decimal(12, 2)
  paid           Decimal         @default(0) @db.Decimal(12, 2)
  status         String          @default("draft") @db.VarChar(20)
  created_at     DateTime        @default(now()) @db.Timestamptz(6)
  updated_at     DateTime        @default(now()) @db.Timestamptz(6)
  claims         claims[]
  invoice_items  invoice_items[]
  encounters     Encounter?      @relation(fields: [encounter_id], references: [id], onUpdate: NoAction)
  patients       Patient         @relation(fields: [patient_id], references: [id], onUpdate: NoAction)
  tenants        Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tenant_id, invoice_number])
  @@index([invoice_number], map: "idx_invoices_number")
  @@index([status], map: "idx_invoices_status")
  @@index([tenant_id, patient_id], map: "idx_invoices_tenant_patient")
  @@map("invoices")
}

model Employee {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id         String              @db.Uuid
  code              String              @db.VarChar(64)
  name              String
  department        String?
  designation       String?
  join_date         DateTime?           @db.Date
  shift             String?             @db.VarChar(16)
  salary            Decimal             @default(0) @db.Decimal(12, 2)
  leave_balance     Decimal             @default(12) @db.Decimal(5, 1)
  created_at        DateTime            @default(now()) @db.Timestamptz(6)
  updated_at        DateTime            @default(now()) @db.Timestamptz(6)
  supervisor_id     String?             @db.Uuid
  attendance        attendance[]
  employee_leaves   employee_leaves[]
  employees         Employee?           @relation("employeesToemployees", fields: [supervisor_id], references: [id], onUpdate: NoAction)
  other_employees   Employee[]          @relation("employeesToemployees")
  tenants           Tenant              @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  payroll_items     payroll_items[]
  payslips          payslips[]
  salary_structures salary_structures[]

  @@unique([tenant_id, code])
  @@index([code], map: "idx_employees_code")
  @@index([tenant_id], map: "idx_employees_tenant")
  @@map("employees")
}

model Department {
  id                                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id                            String             @db.Uuid
  name                                 String
  code                                 String             @db.VarChar(32)
  hod_user_id                          String?            @db.Uuid
  status                               String             @default("active") @db.VarChar(16)
  created_by                           String?            @db.Uuid
  created_at                           DateTime           @default(now()) @db.Timestamptz(6)
  updated_at                           DateTime           @default(now()) @db.Timestamptz(6)
  users_departments_created_byTousers  User?              @relation("departments_created_byTousers", fields: [created_by], references: [id], onUpdate: NoAction)
  users_departments_hod_user_idTousers User?              @relation("departments_hod_user_idTousers", fields: [hod_user_id], references: [id], onUpdate: NoAction)
  tenants                              Tenant             @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  frontdesk_visits                     frontdesk_visits[]

  @@unique([tenant_id, code])
  @@unique([tenant_id, name])
  @@index([tenant_id, status], map: "idx_departments_tenant_status")
  @@map("departments")
}

model Service {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String?   @db.Uuid
  name        String
  code        String
  category    String
  base_rate   Decimal   @default(0) @db.Decimal
  tax_percent Decimal   @default(0) @db.Decimal
  status      String?   @default("active")
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)
  tenants     Tenant?   @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("services")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ambulances {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id      String?   @db.Uuid
  vehicle_number String    @db.VarChar(20)
  model          String?   @db.VarChar(100)
  status         String?   @default("Available") @db.VarChar(20)
  lat            Decimal?  @db.Decimal
  lng            Decimal?  @db.Decimal
  current_driver String?   @db.VarChar(100)
  contact_number String?   @db.VarChar(20)
  created_at     DateTime? @default(now()) @db.Timestamptz(6)
  updated_at     DateTime? @default(now()) @db.Timestamptz(6)
  tenants        Tenant?   @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model attendance {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String    @db.Uuid
  employee_id String    @db.Uuid
  date        DateTime  @default(dbgenerated("CURRENT_DATE")) @db.Date
  check_in    DateTime? @db.Timestamptz(6)
  check_out   DateTime? @db.Timestamptz(6)
  status      String?   @default("Present") @db.VarChar(16)
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime  @default(now()) @db.Timestamptz(6)
  employees   Employee  @relation(fields: [employee_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tenants     Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tenant_id, employee_id, date])
  @@index([date], map: "idx_attendance_date")
  @@index([employee_id], map: "idx_attendance_employee")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model audit_logs {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String?  @db.Uuid
  user_id     String?  @db.Uuid
  user_name   String?
  action      String
  entity_name String?
  entity_id   String?
  details     Json?    @default("{}")
  ip_address  String?  @db.Inet
  user_agent  String?
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  tenants     Tenant?  @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users       User?    @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@index([tenant_id, created_at(sort: Desc)], map: "idx_audit_logs_tenant_created")
  @@index([user_id], map: "idx_audit_logs_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model beds {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  ward_id    String   @db.Uuid
  bed_number String   @db.VarChar(16)
  status     String?  @default("Available") @db.VarChar(16)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  tenants    Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  wards      wards    @relation(fields: [ward_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tenant_id, ward_id, bed_number])
  @@index([status], map: "idx_beds_status")
  @@index([ward_id], map: "idx_beds_ward")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model blood_requests {
  id                                       String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id                                String     @db.Uuid
  patient_id                               String     @db.Uuid
  encounter_id                             String?    @db.Uuid
  requested_group                          String     @db.VarChar(8)
  component                                String     @db.VarChar(24)
  units_requested                          Int
  units_issued                             Int        @default(0)
  priority                                 String     @default("routine") @db.VarChar(16)
  status                                   String     @default("pending") @db.VarChar(24)
  indication                               String?
  requested_by                             String?    @db.Uuid
  approved_by                              String?    @db.Uuid
  approved_at                              DateTime?  @db.Timestamptz(6)
  fulfilled_at                             DateTime?  @db.Timestamptz(6)
  created_at                               DateTime   @default(now()) @db.Timestamptz(6)
  updated_at                               DateTime   @default(now()) @db.Timestamptz(6)
  users_blood_requests_approved_byTousers  User?      @relation("blood_requests_approved_byTousers", fields: [approved_by], references: [id], onUpdate: NoAction)
  encounters                               Encounter? @relation(fields: [encounter_id], references: [id], onUpdate: NoAction)
  patients                                 Patient    @relation(fields: [patient_id], references: [id], onUpdate: NoAction)
  users_blood_requests_requested_byTousers User?      @relation("blood_requests_requested_byTousers", fields: [requested_by], references: [id], onUpdate: NoAction)
  tenants                                  Tenant     @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenant_id, status, priority, created_at(sort: Desc)], map: "idx_blood_requests_tenant_status")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
